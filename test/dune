(rule
 (target cbor_appendix_a_data.ml)
 (deps cbor_appendix_a.json)
 (action
  (with-stdout-to
   %{target}
   (progn
    (echo "let json = {json|")
    (cat %{deps})
    (echo "|json}\n")))))

